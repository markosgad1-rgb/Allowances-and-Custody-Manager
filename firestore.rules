rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Match patterns
    match /users/{userId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;

      match /transactions/{transactionId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if true;
      }
    }
  }
}
