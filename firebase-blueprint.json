{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account for admin or employee",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "jobNumber": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "jobNumber", "email", "role", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An allowance or custody transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "custody": { "type": "number" },
        "allowance": { "type": "number" },
        "addedBy": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "notes", "custody", "allowance", "addedBy", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user accounts"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Subcollection of transactions for a specific user"
    }
  }
}
